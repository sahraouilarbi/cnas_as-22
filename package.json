{
  "name": "cnas-as-22",
  "version": "1.0.0",
  "description": "Application de Gestion du Formulaire CNAS AS-22",
  "main": "electron-main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "start": "concurrently \"npm start --prefix server\" \"npm run build --prefix client && npm run preview --prefix client\"",
    "install-all": "npm install && npm install --prefix client && npm install --prefix server && node server/db/init.js",
    "electron:dev": "concurrently \"npm run dev --prefix client\" \"npm run dev --prefix server\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build --prefix client && electron-builder",
    "electron:build:win": "npm run build --prefix client && electron-builder --win",
    "electron:build:mac": "npm run build --prefix client && electron-builder --mac"
  },
  "build": {
    "appId": "com.cnas.as-22",
    "productName": "CNAS AS-22",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-main.js",
      "server/**/*",
      "client/dist/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "CNAS AS-22"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "morgan": "^1.10.1"
  }
}
